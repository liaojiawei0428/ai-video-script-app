#!/usr/bin/env bash
# .husky/commit-msg — husky 9 hook, 拦 commit message 不含 BUG 编号 (AGENTS.md § 4 铁律 6)
# 配套: tools/check-commit-message.py 1 unstaged 模式
#
# S75 #1 实战 (2026-07-03): 用 husky 9 新版 .husky/ 机制替代老 .git/hooks/ 安装脚本
# 配套 BUG-091/093 (S72 batch 6/7): 任何 commit message 缺 BUG-NNN 或 规范修订 字样直接 reject
# 配套 S74 bump-version.py: --commit 必带 --bug-no, 手写 commit 也必须强制
#
# 兼容写法: Windows + Linux 都支持
# 优先级: 1) 环境变量 $PYTHON 2) Windows 真实 Python 路径 (避 Microsoft Store alias 坑) 3) python3/python/py fallback

COMMIT_MSG_FILE="$1"
if [ -f "$COMMIT_MSG_FILE" ]; then
  MSG=$(head -1 "$COMMIT_MSG_FILE")
  # 跨平台 Python 兼容 (避 Microsoft Store 占位 .exe 坑)
  if [ -n "$PYTHON" ]; then
    PY_CMD="$PYTHON"
  elif [ -x "/c/Users/Administrator/AppData/Local/Python/bin/python.exe" ]; then
    # Windows 真实 Python 路径 (避 WindowsApps 占位)
    PY_CMD="/c/Users/Administrator/AppData/Local/Python/bin/python.exe"
  elif [ -x "/c/Python311/python.exe" ]; then
    PY_CMD="/c/Python311/python.exe"
  elif [ -x "/c/Python312/python.exe" ]; then
    PY_CMD="/c/Python312/python.exe"
  elif [ -x "/c/Python313/python.exe" ]; then
    PY_CMD="/c/Python313/python.exe"
  elif [ -x "/c/Python314/python.exe" ]; then
    PY_CMD="/c/Python314/python.exe"
  elif command -v python3 > /dev/null 2>&1 && ! command -v python3 | grep -q "WindowsApps"; then
    # python3 路径不能是 WindowsApps (那是 Microsoft Store 占位)
    PY_CMD="python3"
  elif command -v python > /dev/null 2>&1; then
    PY_CMD="python"
  elif command -v py > /dev/null 2>&1 && ! command -v py | grep -q "WindowsApps"; then
    PY_CMD="py"
  else
    echo "❌ husky commit-msg: 找不到 python"
    echo "   1) 设 \$PYTHON 环境变量指向 python.exe"
    echo "   2) 或装 Python 3+ 到标准路径 (C:\\Python311 或 C:\\Users\\xxx\\AppData\\Local\\Python)"
    echo "   3) 或修 .husky/commit-msg 加你的 Python 路径"
    exit 1
  fi
  echo "$MSG" | $PY_CMD tools/check-commit-message.py 1 unstaged || exit 1
fi