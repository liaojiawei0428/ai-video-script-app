# Deep剧本 Server 环境变量 (Production Reference)
#
# 复制到 .env 后填入真实值 (跟 docs/ENV_MANAGEMENT.md § 3 配合使用):
#   cp .env.example .env
#   vi .env  # 填真实 key
#
# ⚠️ .env 永不入 git (.gitignore 已加), 部署时手动 scp 或 pm2 env 注入
# ⚠️ 必填项用 [REQUIRED] 标注, 缺失会导致 server 启动失败

# ───── [REQUIRED] 基础 ─────
PORT=6000
NODE_ENV=production                                # development / production
APP_VERSION=3.0.29                                # 跟 ecosystem.config.js 同步 (VERSION_MANAGEMENT § 2 6 处自检)

# ───── [REQUIRED] JWT 鉴权 ─────
# 强密钥 256-bit (openssl rand -hex 32) — 改了所有用户 token 失效, 必重新登录
JWT_SECRET=replace_with_openssl_rand_hex_32

# ───── [REQUIRED] MySQL 数据库 (10.1.0.11 远程) ─────
MYSQL_HOST=10.1.0.11
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=ai_script
MYSQL_POOL_SIZE=10                                # 连接池, 默认 10 够用

# ───── [REQUIRED] DeepSeek LLM (V4 Flash 多 Key 池) ─────
# 多个 key 用英文逗号分隔, server 启动时随机选一个 (key 轮换 + 限流分摊)
DEEPSEEK_API_KEYS=sk-key1,sk-key2,sk-key3
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ───── [OPTIONAL] Agnes API 限流排队配置 (v3.0.52 BUG-123 起) ─────
# 图片生成限流 (默认 40 次/分钟), 超过自动排队 + ETA 估算
AGNES_IMAGE_RATE_LIMIT=40
AGNES_IMAGE_RATE_WINDOW_MS=60000
# 视频生成限流 (默认 2 次/分钟), 超过自动排队 + ETA 估算
AGNES_VIDEO_RATE_LIMIT=2
AGNES_VIDEO_RATE_WINDOW_MS=60000

# ───── [REQUIRED] Agnes AI (3 个企业独立 API Key, v3.0.51 BUG-122 起) ─────
# Agnes Image 2.1 Flash + Agnes 2.0 Flash (text) + Agnes Video V2.0 各自独立企业 key
# 3 key 各自配额独立 (互不抢 QPS), 企业版并发更高, shipin-APP 实战强烈推荐拆分
# 优先级 (server 端 3 个 provider 读法):
#   - text 端  → AGNES_TEXT_API_KEY  > AGNES_API_KEY  > AGNES_IMAGE_API_KEY
#   - image 端 → AGNES_IMAGE_API_KEY > AGNES_API_KEY  (字段名复用 = 专用 + 老兼容合并)
#   - video 端 → AGNES_VIDEO_API_KEY > AGNES_API_KEY  > AGNES_IMAGE_API_KEY
AGNES_TEXT_API_KEY=wk-your_text_enterprise_key_here
AGNES_IMAGE_API_KEY=wk-your_image_enterprise_key_here
AGNES_VIDEO_API_KEY=wk-your_video_enterprise_key_here
# 兼容老配置 (v3.0.0 之前 shipin-APP 用 1 把 key 调所有端点, 仍然有效, 但并发受限)
# AGNES_API_KEY=sk-legacy_unified_key
# ZHIPU_IMAGE_API_KEY=fallback (智谱生图兜底, v2.5.x 历史)

# ───── [REQUIRED] 支付 (支付宝 / 微信, 充值用) ─────
PAY_KEY=your_payment_sign_key_here
# 支付宝
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_NOTIFY_URL=https://ab.maque.uno/api/recharge/alipay/notify

# ───── [OPTIONAL] 文件上传 ─────
UPLOAD_DIR=./uploads                              # 用户上传目录, 部署后永不动
MAX_FILE_SIZE=52428800                            # 50MB

# ───── [OPTIONAL] CORS ─────
CORS_ORIGIN=*                                     # 生产改具体域名

# ───── [OPTIONAL] Rate Limiting ─────
RATE_LIMIT_WINDOW_MS=60000                        # 1 分钟窗口
RATE_LIMIT_MAX_REQUESTS=10                        # 每 IP 每窗口 10 次

# ───── [OPTIONAL] 代理 (中国大陆生产部署时必填, 海外直连不需要) ─────
HTTP_PROXY=
HTTPS_PROXY=
http_proxy=
https_proxy=
SOCKS_PROXY=
SOCKS5_PROXY=
ALL_PROXY=

# ───── [OPTIONAL] 内部调试 ─────
DEBUG=false                                       # true 时输出 SQL 语句 + 详细错误堆栈
LOG_LEVEL=info                                    # error / warn / info / debug

# ───── 字段兼容性 (老配置不删, 留作历史, 见 VERSION_MANAGEMENT § 3) ─────
# REDIS_URL=redis://localhost:6379               # v1.x 历史, shipin-APP 实际不用 (用 MySQL LRU 替代)
# DB_PATH=./data/app.db                          # v1.x SQLite 历史, v2.x 切 MySQL
