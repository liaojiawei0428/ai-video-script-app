PORT=6000
NODE_ENV=development

# Deepseek API
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Redis
REDIS_URL=redis://localhost:6379

# Database
DB_PATH=./data/app.db

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# ── v3.0.0 Agnes AI (统一 API key, 3 个模型通用) ──
# Agnes Image 2.1 Flash + Agnes 2.0 Flash (text) + Agnes Video V2.0 都用这一个 key
# 同一个 API Key 可调用 https://apihub.agnes-ai.com 的所有端点
AGNES_API_KEY=sk-your_agnes_key_here
# 兼容旧名 (v2.5.x 历史, 新部署不用配)
# AGNES_IMAGE_API_KEY=sk-legacy_key
# 模型参数调优, 见 config.toml
