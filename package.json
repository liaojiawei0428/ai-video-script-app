{
  "name": "ai-video-script-app",
  "private": true,
  "version": "1.0.0",
  "description": "AI视频剧本生成应用 - 将小说转换为标准AI视频剧本",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "npm --prefix apps/server run lint && npm --prefix apps/web run lint",
    "lint:fix": "npm --prefix apps/server run lint:fix && npm --prefix apps/web run lint:fix && prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml}\" --ignore-path .gitignore",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml}\" --ignore-path .gitignore",
    "typecheck": "npm --prefix apps/server run typecheck && npm --prefix apps/web run typecheck",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  }
}
